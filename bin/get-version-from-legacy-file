#!/usr/bin/env bash

get_legacy_version() {
    local -r current_directory="$1"
    local -r tf_version_file="${current_directory}/.tfswitchrc"

    # Get version from .tfswitchrc file (used by tfswitch)
    if [[ -r ${tf_version_file} ]]; then
        cat "${tf_version_file}"
    fi
}

get_legacy_version "$1"
